[gd_scene load_steps=9 format=3 uid="uid://cxkpqtjpofrd0"]

[sub_resource type="GDScript" id="GDScript_gmi6l"]
script/source = "extends Node2D

@onready var timerRef = $intensityTimer
@onready var socialBarRef = $socialBar
@onready var satietyBarRef = $satietyBar
@onready var moneyBarRef = $moneyBar
@onready var loseLabel = $placeholderLoseLabel

func _ready():
	timerRef.start()

func _progress():
	pass

# Natural decrease of the needs bar
func _on_timer_timeout() -> void:
	socialBarRef.value = socialBarRef.value - 1
	satietyBarRef.value = satietyBarRef.value - .1
	moneyBarRef.value = moneyBarRef.value - .1

func socialBarValueChanged(value: float) -> void:
	if(socialBarRef.value <= 0 || satietyBarRef.value <= 0 || moneyBarRef.value <= 0):
		gameLost()

func gameLost():
	loseLabel.visible = true
	timerRef.stop()
"

